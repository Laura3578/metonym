  <title>Metonym — Clinical evaluation for AI suicide risk detection</title>
  <meta name="description" content="Metonym is a patent-pending clinical methodology for evaluating how AI systems detect — or fail to detect — suicide risk in real conversations.">
  <meta name="robots" content="index,follow">

  <!-- Open Graph -->
  <meta property="og:title" content="Metonym — Clinical evaluation for AI suicide risk detection">
  <meta property="og:description" content="Patent-pending clinical methodology for evaluating AI suicide risk detection systems.">
